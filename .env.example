# BotFather'dan olingan bot tokeni
BOT_TOKEN=123456789:AAExampleTokenHere

# Sizning shaxsiy Telegram ID'ingiz (adminlik uchun) — @userinfobot orqali bilib olishingiz mumkin
ADMIN_CHAT_ID=123456789

# Frontend endi backend bilan bitta servisda joylashgani uchun, MINI_APP_URL
# odatda shu servisning o'zi bo'ladi (masalan https://sizning-servis.onrender.com).
# Lokal testda bo'sh qoldirsangiz ham bo'ladi.
MINI_APP_URL=https://your-service.onrender.com

# Ma'lumotlar bazasi. Test uchun SQLite (standart).
# Productionda Neon.tech'dan olingan bepul PostgreSQL manzilini qo'ying:
# DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/car_marketplace?sslmode=require
DATABASE_URL=sqlite:///./car_marketplace.db

# Rasmlar saqlanadigan papka (DIQQAT: Render bepul tarifida bu disk vaqtinchalik —
# har safar qayta deploy qilinganda rasm fayllari o'chib ketadi)
UPLOAD_DIR=uploads

# Telegram webhook manzilini himoya qilish uchun tasodifiy maxfiy so'z
# (o'zingiz o'ylab toping, masalan uzun tasodifiy harf-raqamlar)
WEBHOOK_SECRET=changeme-random-secret

# Faqat Render kabi hostingda kerak emas (RENDER_EXTERNAL_URL avtomatik beriladi).
# Boshqa hostingda backend'ning ochiq HTTPS manzilini shu yerga yozing:
# PUBLIC_URL=https://sizning-manzil.com
PUBLIC_URL=

# DIQQAT: faqat lokal test uchun! Productionda albatta "false" bo'lsin
SKIP_TELEGRAM_VALIDATION=true
