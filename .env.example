# BotFather'dan olingan bot tokeni
BOT_TOKEN=123456789:AAExampleTokenHere

# Sizning shaxsiy Telegram ID'ingiz (adminlik uchun) — @userinfobot orqali bilib olishingiz mumkin
ADMIN_CHAT_ID=123456789

# (Ixtiyoriy) Tasdiqlangan e'lonlar avtomatik joylanadigan Telegram kanali.
# 1) Telegram'da kanal yarating (yoki mavjudini ishlating)
# 2) Botingizni kanalga ADMINISTRATOR sifatida qo'shing ("Post Messages" ruxsati bilan)
# 3) Agar kanal ochiq (public) bo'lsa, uning @username'ini shu yerga yozing:
CHANNEL_ID=@sizning_kanal_username

# @BotFather'da /newapp orqali yaratilgan Mini App qisqa nomi (short name).
# Kanal postidagi tugma shu nom orqali Mini App'ni bitta bosishda to'g'ridan-to'g'ri ochadi.
MINI_APP_SHORT_NAME=Autosavdo

# Frontend endi backend bilan bitta servisda joylashgani uchun, MINI_APP_URL
# odatda shu servisning o'zi bo'ladi (masalan https://sizning-servis.onrender.com).
# Lokal testda bo'sh qoldirsangiz ham bo'ladi.
MINI_APP_URL=https://your-service.onrender.com

# Ma'lumotlar bazasi. Test uchun SQLite (standart).
# Productionda Neon.tech'dan olingan bepul PostgreSQL manzilini qo'ying:
# DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/car_marketplace?sslmode=require
DATABASE_URL=sqlite:///./car_marketplace.db

# Rasmlar Cloudflare R2'ga yuklanadi (pastdagi R2_* to'liq to'ldirilsa).
# Sozlanmagan bo'lsa, faqat lokal test uchun shu papkaga (diskka) yoziladi
# (DIQQAT: Render bepul tarifida bu disk vaqtinchalik — har safar qayta
# deploy qilinganda rasm fayllari o'chib ketadi, shuning uchun productionda R2 SHART).
UPLOAD_DIR=uploads

# Cloudflare R2 (rasmlarni doimiy saqlash uchun):
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Telegram webhook manzilini himoya qilish uchun tasodifiy maxfiy so'z
# (o'zingiz o'ylab toping, masalan uzun tasodifiy harf-raqamlar)
WEBHOOK_SECRET=changeme-random-secret

# Faqat Render kabi hostingda kerak emas (RENDER_EXTERNAL_URL avtomatik beriladi).
# Boshqa hostingda backend'ning ochiq HTTPS manzilini shu yerga yozing:
# PUBLIC_URL=https://sizning-manzil.com
PUBLIC_URL=

# DIQQAT: faqat lokal test uchun! Productionda albatta "false" bo'lsin —
# aks holda Telegram initData imzosi umuman tekshirilmay, istalgan foydalanuvchi
# o'zini boshqa birov (jumladan admin) qilib ko'rsatishi mumkin bo'lib qoladi.
# PUBLIC_URL/RENDER_EXTERNAL_URL sozlangan holda "true" qoldirilsa, backend
# (backend/app/main.py) buni avtomatik aniqlab, ishga tushmasdan to'xtaydi.
SKIP_TELEGRAM_VALIDATION=true
